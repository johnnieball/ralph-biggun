# .ralphrc - Ralph loop configuration

# Active plan — resolves to specs/tasks-<name>.json
# e.g. RALPH_PLAN=my-app reads specs/tasks-my-app.json
RALPH_PLAN=

# Maximum API calls per hour (rate limiting)
MAX_CALLS_PER_HOUR=60

# Maximum iterations before stopping (leave unset to auto-compute from task list)
# MAX_ITERATIONS=20

# Circuit breaker: halt after N loops with no file changes
CB_NO_PROGRESS_THRESHOLD=3

# Circuit breaker: halt after N loops with same error
CB_SAME_ERROR_THRESHOLD=5

# Rate limit resilience: wait time in seconds before retrying after API rate limit
RATE_LIMIT_WAIT=120

# Rate limit resilience: max retries before giving up on rate-limited iteration
RATE_LIMIT_MAX_RETRIES=5

# Iteration timeout: max seconds per claude pipeline invocation (0 = no limit)
# ITER_TIMEOUT_SECS=600

# Allowed tools for Claude Code (granular git subcommands for safety)
ALLOWED_TOOLS="Write,Read,Edit,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(bun *),Bash(bunx *)"
