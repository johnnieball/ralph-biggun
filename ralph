#!/bin/bash

# ralph — CLI entry point for Ralph autonomous TDD loop
# Usage: ralph <command> [options]
#
# Commands:
#   init [--stack <preset>] [--blueprint <name>] [--upgrade] [target-dir]
#   run [iterations] [plan-name]                     — Start the autonomous loop
#   task-build <spec-file> [plan-name] [max-iter]    — Generate task list from spec
#   upgrade [--stack <preset>] [target-dir]           — Shorthand for init --upgrade
#   blueprints                                        — List available blueprints

RALPH_HOME="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  init)
    shift
    exec "$RALPH_HOME/commands/init.sh" "$@"
    ;;
  run)
    shift
    exec "$RALPH_HOME/commands/run.sh" "$@"
    ;;
  task-build)
    shift
    exec "$RALPH_HOME/commands/task-build.sh" "$@"
    ;;
  upgrade)
    shift
    exec "$RALPH_HOME/commands/init.sh" --upgrade "$@"
    ;;
  blueprints)
    echo "Available blueprints:"
    for f in "$RALPH_HOME"/blueprints/*.json; do
      [ -f "$f" ] && echo "  - $(basename "$f" .json)"
    done
    ;;
  *)
    echo "Usage: ralph <command> [options]"
    echo ""
    echo "Commands:"
    echo "  init [options] [dir]                       Initialise or upgrade Ralph"
    echo "    --stack <preset>                         Override stack detection"
    echo "    --blueprint <name>                       Load a blueprint task list (greenfield)"
    echo "    --upgrade                                Upgrade existing installation"
    echo "  upgrade [--stack <preset>] [dir]           Shorthand for init --upgrade"
    echo "  run [iterations] [plan-name]               Start the autonomous loop"
    echo "  task-build <spec> [plan-name] [max-iter]   Generate task list from spec file"
    echo "  blueprints                                 List available blueprints"
    echo ""
    echo "Available stack presets:"
    for f in "$RALPH_HOME"/presets/*.sh; do
      echo "  - $(basename "$f" .sh)"
    done
    echo ""
    echo "Available blueprints:"
    for f in "$RALPH_HOME"/blueprints/*.json; do
      [ -f "$f" ] && echo "  - $(basename "$f" .json)"
    done
    ;;
esac
