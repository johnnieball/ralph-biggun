#!/bin/bash

# ralph — CLI entry point for Ralph autonomous TDD loop
# Usage: ralph <command> [options]
#
# Commands:
#   init [--stack <preset>] [target-dir]         — Initialise Ralph in a project
#   run [iterations] [plan-name]                 — Start the autonomous loop
#   prd-build <spec-file> [plan-name] [max-iter] — Generate PRD from spec

RALPH_HOME="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  init)
    shift
    exec "$RALPH_HOME/commands/init.sh" "$@"
    ;;
  run)
    shift
    exec "$RALPH_HOME/commands/run.sh" "$@"
    ;;
  prd-build)
    shift
    exec "$RALPH_HOME/commands/prd-build.sh" "$@"
    ;;
  *)
    echo "Usage: ralph <command> [options]"
    echo ""
    echo "Commands:"
    echo "  init [--stack <preset>] [dir]              Initialise Ralph in a project"
    echo "  run [iterations] [plan-name]               Start the autonomous loop"
    echo "  prd-build <spec> [plan-name] [max-iter]    Generate PRD from spec file"
    echo ""
    echo "Available stack presets:"
    for f in "$RALPH_HOME"/presets/*.sh; do
      echo "  - $(basename "$f" .sh)"
    done
    ;;
esac
